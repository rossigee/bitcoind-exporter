# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bitcoind-exporter
bitcoind-exporter-*

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage.out
coverage.html

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Local environment files
.env
.env.local
.env.*.local

# Logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output

# Temporary folders
tmp/
temp/

# Scripts are allowed
!scripts/
!scripts/*.sh

# Certificate files (don't commit real certs)
*.pem
*.key
*.crt
*.p12
*.pfx

# Config files with secrets
config.yaml
config.yml
config.json

# Test artifacts
gosec-report.json
benchmark.txt

# Docker build artifacts
.dockerignore

# Git hooks
.git/hooks/*
!.git/hooks/pre-commit

# Backup files
*.bak
*.backup

# Pre-commit
.pre-commit-config.yaml.bak
.secrets.baseline.new

# Cache directories
.cache/